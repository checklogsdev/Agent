# CheckLogs Agent Configuration
# Copy this file to .env and fill in your values

# =============================================
# REQUIRED: Get these from your CheckLogs dashboard
# =============================================
CHECKLOGS_API_KEY=your_api_key_here
CHECKLOGS_API_PORT=your_udp_port_here

# =============================================
# OPTIONAL: Server identification
# =============================================
SERVER_NAME=My Production Server

# =============================================
# OPTIONAL: Collection settings
# =============================================
COLLECT_INTERVAL=10
COLLECT_CPU=true
COLLECT_RAM=true
COLLECT_DISK=true
COLLECT_LOAD=true
COLLECT_PROCESSES=true
TOP_PROCESSES_COUNT=10

# =============================================
# OPTIONAL: Logging
# =============================================
LOG_LEVEL=info

# =============================================
# NOTE: You don't need to configure any IP address!
# The agent automatically sends data to api.checklogs.dev
# =============================================