# CheckLogs Agent Configuration
# Copier ce fichier en .env et remplir les valeurs

# =============================================
# API CheckLogs (fournie lors de l'inscription)
# =============================================
CHECKLOGS_API_HOST=api.checklogs.dev
CHECKLOGS_API_PORT=9876
CHECKLOGS_API_KEY=your_api_key_here

# =============================================
# Informations du serveur
# =============================================
SERVER_NAME=My Production Server
SERVER_HOSTNAME=auto

# =============================================
# Fréquence de collecte
# =============================================
# Intervalle en secondes entre chaque collecte (défaut: 10s)
COLLECT_INTERVAL=10

# =============================================
# Métriques à collecter
# =============================================
COLLECT_CPU=true
COLLECT_RAM=true
COLLECT_DISK=true
COLLECT_LOAD=true
COLLECT_PROCESSES=true
COLLECT_NETWORK=false

# =============================================
# Configuration des processus
# =============================================
# Nombre de processus à remonter (top CPU/RAM)
TOP_PROCESSES_COUNT=10

# =============================================
# Détection d'anomalies
# =============================================
# Activer la détection d'anomalies
ANOMALY_DETECTION=true

# Seuil de déviation pour alerter (en %)
ANOMALY_THRESHOLD=50

# =============================================
# Logs
# =============================================
# Niveaux: debug, info, warn, error
LOG_LEVEL=info
